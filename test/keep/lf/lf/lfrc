# ==============================================================================
# LF CONFIG - WINDOWS (PowerShell)
# ==============================================================================

# Interpreter settings
set shell pwsh
set shellflag -c
set shellopts -NoProfile


cmd edit $nvim $env:f
map e edit


# UI Settings
set scrolloff 10
set icons false
set info custom
set previewer ~\\vimfiles\\test\\keep\\lf\\lf\\preview.bat

# ------------------------------------------------------------------------------
# BASIC MAPPINGS (Aligned with Linux)
# ------------------------------------------------------------------------------

map i $bat --style=plain --color=always --paging=auto $env:f
map <enter> read
map ; read

# Open operations
map oc $code ($env:fx -split '\r?\n')
map oe $nvim ($env:fx -split '\r?\n')
map ov $gvim ($env:fx -split '\r?\n')
map on $nvim-qt ($env:fx -split '\r?\n')
map oz &7zFM ($env:fx -split '\r?\n')
map ox &explorer.exe $env:f
map os &Start-Process -FilePath ($env:fx -split '\r?\n')

# Deletion / Diff / Disk Usage
map d
map dd cut
map dD delete
map <delete> delete
map dv :vdiff
map dc :diff
map du ${{
    if((Get-Item $env:f).PSIsContainer) { dua interactive $env:f } else { dua interactive }
}}

# Rename and Git
map r
map rr rename
map rg $lg.exe
map gi $lg.exe

# Copy/Paste/Selection (Mirroring Linux "a" prefix)
map c
map cw rename
map cc :clear ; unselect

map a
map aa invert
map ap paste
map ay copy
map ad cut
map ac clear

map y
map yy copy
map yb &{{ (Get-Item $env:f).Name | clip.exe }}
map yd &{{ (Get-Item $env:f).DirectoryName | clip.exe }}

map v
map vv invert
map ve $nvim $env:f
map vd $wsl -e /home/sabre/.local/bin/visidata (wsl wslpath ($env:f.Replace('\', '/')))

# ------------------------------------------------------------------------------
# CUSTOM COMMANDS
# ------------------------------------------------------------------------------

# Zoxide
cmd z ${{
    $res = zoxide query --exclude $env:PWD $args
    if ($res) {
        $res = $res -replace "\\", "\\" -replace "'", "''"
        lf -remote "send $env:id cd '$res'"
    }
}}

cmd zi ${{
    $res = zoxide query -i
    if ($res) {
        $res = $res -replace "\\", "\\" -replace "'", "''"
        lf -remote "send $env:id cd '$res'"
    }
}}
map zi :zi

# FZF File Jump
cmd fzf_file_jump ${{
    $res = fd --hidden --exclude .git | fzf --reverse --preview 'bat --color=always --style=plain {}'
    if ($res) {
        $cmd = if ((Get-Item $res).PSIsContainer) { "cd" } else { "select" }
        $res = $res -replace "\\", "\\" -replace '"', '\"'
        lf -remote "send $env:id $cmd `"$res`""
    }
}}
map gf :fzf_file_jump

# FZF Search Text
cmd fzf_search_text ${{
    $rg_cmd = "rg --column --line-number --no-heading --color=always --smart-case"
    $res = fzf --ansi --disabled --layout=reverse --header="Search in files" `
        --bind "start:reload($rg_cmd {q})" --bind "change:reload($rg_cmd {q})"
    if ($res) {
        $file = ($res -split ':')[0] -replace "\\", "\\" -replace '"', '\"'
        lf -remote "send $env:id select `"$file`""
    }
}}
map gt :fzf_search_text

# Git Root Jump
map gr ${{
    $t = (git rev-parse --show-toplevel 2>$null)
    if ($t) {
        $t = $t -replace "\\", "\\"
        lf -remote "send $env:id cd `"$t`""
    }
}}

# ------------------------------------------------------------------------------
# EVENT HOOKS
# ------------------------------------------------------------------------------

cmd on-cd &{{
    $OutputEncoding = [System.Text.Encoding]::UTF8
    [Console]::OutputEncoding = [System.Text.Encoding]::UTF8

    zoxide add "$env:PWD"

    $cfg = "$env:USERPROFILE\.config\starship_lf.toml"

    if (Test-Path $cfg) {
        $env:STARSHIP_CONFIG = $cfg
        $fmt = starship prompt
        Remove-Item Env:STARSHIP_CONFIG # Clean up
    } else {
        $fmt = starship prompt
    }

    $fmt = ($fmt -split "`r?`n" -join "") -replace "\\", "\\" -replace '"', '\"' -replace "%", "%%"

    lf -remote "send $env:id set promptfmt `"$fmt`""
}}

# Enhanced Status Bar via eza
cmd on-select &{{
    $info = (eza -ld --color=always "$env:f")
    # Escape quotes for the remote command
    $info = $info -replace '"', '\"'
    lf -remote "send $env:id set statfmt `"$info`""
}}

