# ==============================================================================
# SECTION 1: GLOBAL ENVIRONMENT (Run once per session, inherited by subshells)
# ==============================================================================

if [ -z "$__BASHRC1_ENV_LOADED" ]; then
    export __BASHRC1_ENV_LOADED=1

    # Track sourcing for debugging
    export NUM_TIMES_SOURCED=$(( ${NUM_TIMES_SOURCED:-0} + 1 ))

    # Determine shell type
    [ -n "$ZSH_VERSION" ] && CURSHELL=zsh || CURSHELL=bash
    export EDITOR=nvim

    # --- System Profile Evaluation ---
    if [ -z "${FORCE_ONLY_ONE_EVAL_SYSTEM_PROFILE+x}" ]; then
        now_profile=$SECONDS
        if (( now_profile >= 3 )); then
            [ -f /etc/bashrc ] && . /etc/bashrc
            if [[ "$USER" != *"ark-research"* ]]; then
                [ -f /etc/profile ] && . /etc/profile
            fi
        fi
        export FORCE_ONLY_ONE_EVAL_SYSTEM_PROFILE=1
    fi

    # --- PATH and Library Modifications ---
    export PATH=${HOME}/.local/bin:${PATH}
    export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:+$LD_LIBRARY_PATH:}/tmp/${HOME}/lib"
    export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:+$LD_LIBRARY_PATH:}/tmp/$USER/lib"
    export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:+$LD_LIBRARY_PATH:}/tmp/$USER/usr/lib"
    export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:+$LD_LIBRARY_PATH:}${HOME}/lib"
    export MANPATH="${MANPATH:+$MANPATH:}/tmp/$USER/man:/tmp/$USER/local/man"

    [[ -f /proc/sys/fs/binfmt_misc/WSLInterop ]] && IS_WSL=1 || IS_WSL=0
    export IS_WSL
    export IS_GIT_BASH="$([ -n "${MINGW_PREFIX}" ] && echo 1  || echo 0)"
    export PYTHONSTARTUP=~/.pythonrc.py
    export DISPLAY0="$DISPLAY"
    export PYTHONPYCACHEPREFIX=/tmp/pycache

    if [ "${IS_GIT_BASH}" = "1" ]; then
        export PATH="/c/ht/nvim-win64/bin:${PATH}"
    else
        export PATH="${HOME}/bin/links:${PATH}"
    fi

    [ -e "$HOME/bin" ] && export PATH="${HOME}/bin:${PATH}"
    [ -e "$HOME/.cargo/bin" ] && export PATH="${HOME}/.cargo/bin:${PATH}"
fi

# ==============================================================================
# SECTION 2: INTERACTIVE SETTINGS (Run for every new shell process/tmux window)
# ==============================================================================

# Helper functions for path management (must be defined for aliases/local scripts)
function addfolderstovariables () {
    local DROOT="$1"
    export PATH="$DROOT/bin":"${PATH}"; export LD_LIBRARY_PATH="$DROOT/lib":"${LD_LIBRARY_PATH}"
    export MANPATH="$DROOT/share/man":"$MANPATH"
}

function addDirToVarsFront() {
    local d="$1"; [[ ! -d "$d" ]] && return
    export PATH="$d/bin:$PATH"
    [[ -d "$d/lib" ]] && export LD_LIBRARY_PATH="$d/lib:$LD_LIBRARY_PATH"
    [[ -d "$d/share/man" ]] && export MANPATH="$d/share/man:$MANPATH"
}

function dupremove() {
    # Canonical definition is in bashrc2; this is a minimal fallback
    # in case bashrc2 hasn't been sourced yet (used at end of bashrc1)
    local __dupremovevar; local _result
    if [ -z "$1" ]; then dupremove PATH; dupremove LD_LIBRARY_PATH; dupremove MANPATH; return; fi
    eval __dupremovevar=\$$1
    _result=$(awk 'BEGIN{ORS=":";RS="[:\n]"}!a[$0]++' <<<"${__dupremovevar%:}" | sed -e 's/\:\:/\:/g' -e 's/:$//')
    eval "export ${1}=\"${_result:-${__dupremovevar}}\" "
}

function _eval_cmd_expression_if_exists {
    if ! command -v $1 >& /dev/null; then return; fi
    eval "$($@)"
}

# --- Load Interactive Components ---
if [[ -n "$PS1" ]]; then

    if [ -z "${CONFIG_FILES_DIR}" ]; then
        export CONFIG_FILES_DIR="${HOME}"
        export CONFIG_DOT_PREFIX="."
    fi

    # 1. Aliases & Functions (Inheritance doesn't pass these, so load every time)
    [ -e "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}alias" ] && . "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}alias"
    [ -e "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}bashrc2" ] && . "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}bashrc2"
    [ -e "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}wk2.sh" ] && . "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}wk2.sh"

    # 2. Local Completions
    [ -e "$HOME/bin/links/completions/comp.bash" ] && . "$HOME/bin/links/completions/comp.bash"

    # 3. Prompt (prompt.sh logic)
    # Inside prompt.sh, ensure DID_PROMPT_SET is NOT exported
    [ -e "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}prompt.sh" ] && . "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}prompt.sh"

    # 4. Windows Specifics
    if [ "${BASH_CONFIG_IMPORT_WIN}" = "yes" ]; then
        [ -e "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}bashrc_win" ] && . "${CONFIG_FILES_DIR}/${CONFIG_DOT_PREFIX}bashrc_win"
    fi

    # 5. Local machine overrides
    [ -e "${HOME}/.bashrc.local" ] && . "${HOME}/.bashrc.local"

    # 6. Final Clean up & Interactive tools
    export HISTCONTROL=erasedups:ignoredups:ignorespace
    _eval_cmd_expression_if_exists fzf --${CURSHELL:-bash}

    # Run deduplication one last time to keep the inherited PATH healthy
    dupremove PATH
fi

