#!/usr/bin/env bash
NEW_ARGS=()
SKIP_NEXT=false

REAL_ZIG=/mnt/disks/data/ark-research-svcdel/.nix-profile/bin/zig

# Intercept and swap out modern targets for RHEL 8 glibc 2.28
for ((i = 1; i <= $#; i++)); do
  if [ "$SKIP_NEXT" = true ]; then
    SKIP_NEXT=false
    continue
  fi
  arg="${!i}"
  if [ "$arg" = "-target" ]; then
    NEW_ARGS+=("-target" "x86_64-linux-gnu.2.28")
    SKIP_NEXT=true
  else
    NEW_ARGS+=("$arg")
  fi
done

# Injects target definitions depending on how zig is invoked
if [ "${NEW_ARGS[0]}" = "build" ]; then
  case "${NEW_ARGS[@]}" in
  *"-Dtarget="*) ;;
  *) NEW_ARGS+=("-Dtarget=x86_64-linux.2.28") ;;
  esac
else
  case "${NEW_ARGS[@]}" in
  *"-target"*) ;;
  *)
    if [[ "${NEW_ARGS[0]}" == "build-lib" || "${NEW_ARGS[0]}" == "build-exe" || "${NEW_ARGS[0]}" == "build-obj" || "${NEW_ARGS[0]}" == "cc" || "${NEW_ARGS[0]}" == "c++" ]]; then
      NEW_ARGS+=("-target" "x86_64-linux-gnu.2.28")
    fi
    ;;
  esac
fi

exec "$REAL_ZIG" "${NEW_ARGS[@]}"
